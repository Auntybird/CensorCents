# ============================================================================
# TIGER WALLET — Environment Secrets
# Copy this file to ".env" (same folder) and fill in real values.
# NEVER commit the real ".env" file — add it to .gitignore.
# ============================================================================

# Supabase project settings -> API
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Groq Cloud console -> API Keys (https://console.groq.com/keys)
GROQ_API_KEY=
# Model to use — Llama 3 family hosted on Groq
GROQ_MODEL=llama-3.3-70b-versatile
